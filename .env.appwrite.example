# Appwrite backend provisioning credentials.
#
# Copy this file to `.env.appwrite.local` (gitignored) and fill in real values.
# These are used ONLY by the server-side setup/migration script
# (scripts/appwrite/setup.mjs). The API key is a SECRET — never commit it and
# never expose it to the React Native client.

# Appwrite API endpoint, e.g. https://cloud.appwrite.io/v1 (or your self-hosted URL)
APPWRITE_ENDPOINT=

# Project ID from the Appwrite console
APPWRITE_PROJECT_ID=

# Server API key with scopes: databases.read, databases.write,
# collections.read, collections.write, attributes.write, indexes.write,
# documents.read, documents.write
APPWRITE_API_KEY=

# Existing database ID to provision into (defaults to piggnify_mobile_db)
APPWRITE_DATABASE_ID=piggnify_mobile_db

# ─── Client-side (safe to expose; mirror into .env as EXPO_PUBLIC_* later) ───
# EXPO_PUBLIC_APPWRITE_ENDPOINT=
# EXPO_PUBLIC_APPWRITE_PROJECT_ID=
# EXPO_PUBLIC_APPWRITE_DATABASE_ID=piggy
